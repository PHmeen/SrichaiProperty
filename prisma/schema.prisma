generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}


/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model agent_availabilities {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_id       String?  @db.Uuid
  available_date DateTime @db.Date
  time_slot      String?  @db.VarChar(20)
  is_booked      Boolean? @default(false)
  created_at     DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users          users?   @relation(fields: [agent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([agent_id, available_date, time_slot])
}

model amenities {
  id                 Int                  @id @default(autoincrement())
  name               String               @unique @db.VarChar(100)
  created_at         DateTime             @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  property_amenities property_amenities[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model appointments {
  id                                    String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id                           String?     @db.Uuid
  agent_id                              String?     @db.Uuid
  property_id                           String?     @db.Uuid
  appointment_date                      DateTime    @db.Date
  time_slot                             String?     @db.VarChar(20)
  status                                String?     @default("pending") @db.VarChar(20)
  note                                  String?
  created_at                            DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users_appointments_agent_idTousers    users?      @relation("appointments_agent_idTousers", fields: [agent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_appointments_customer_idTousers users?      @relation("appointments_customer_idTousers", fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  properties                            properties? @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reviews                               reviews?

  @@index([agent_id], map: "idx_appointments_agent")
  @@index([customer_id], map: "idx_appointments_customer")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model banner_campaigns {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title      String   @db.VarChar(100)
  image_url  String   @db.VarChar(255)
  link_url   String?  @db.VarChar(255)
  start_date DateTime @db.Date
  end_date   DateTime @db.Date
  status     String?  @default("inactive") @db.VarChar(20)
  created_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
}

model chat_sessions {
  id                                     String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id                            String?     @db.Uuid
  agent_id                               String?     @db.Uuid
  property_id                            String?     @db.Uuid
  created_at                             DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users_chat_sessions_agent_idTousers    users?      @relation("chat_sessions_agent_idTousers", fields: [agent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_chat_sessions_customer_idTousers users?      @relation("chat_sessions_customer_idTousers", fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  properties                             properties? @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages                               messages[]

  @@unique([customer_id, agent_id, property_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model listing_package_orders {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  property_id          String?                @db.Uuid
  package_id           Int?
  start_date           DateTime               @db.Date
  end_date             DateTime               @db.Date
  status               String?                @default("pending") @db.VarChar(20)
  created_at           DateTime               @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  listing_packages     listing_packages?      @relation(fields: [package_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  properties           properties?            @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payment_transactions payment_transactions[]
}

model listing_packages {
  id                     Int                      @id @default(autoincrement())
  name                   String                   @unique @db.VarChar(50)
  price                  Decimal                  @db.Decimal(10, 2)
  max_duration_days      Int
  created_at             DateTime                 @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  listing_package_orders listing_package_orders[]
}

model login_histories {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?  @db.Uuid
  ip_address String?  @db.VarChar(45)
  user_agent String?
  created_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users      users?   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model messages {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id    String?        @db.Uuid
  sender_id     String?        @db.Uuid
  content       String?
  file_url      String?        @db.VarChar(255)
  latitude      Decimal?       @db.Decimal(10, 8)
  longitude     Decimal?       @db.Decimal(11, 8)
  created_at    DateTime       @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users         users?         @relation(fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  chat_sessions chat_sessions? @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([session_id], map: "idx_messages_session")
}

model nearby_places {
  id                Int                 @id @default(autoincrement())
  name              String              @db.VarChar(150)
  type              String?             @db.VarChar(50)
  created_at        DateTime            @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  property_nearbies property_nearbies[]
}

model notifications {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?  @db.Uuid
  title      String   @db.VarChar(150)
  content    String
  is_read    Boolean? @default(false)
  type       String?  @db.VarChar(50)
  created_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users      users?   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_notifications_user_unread", where: raw("(is_read = false)"))
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model payment_transactions {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id               String?                 @db.Uuid
  amount                 Decimal                 @db.Decimal(10, 2)
  payment_method         String?                 @db.VarChar(50)
  slip_url               String?                 @db.VarChar(255)
  status                 String?                 @default("pending") @db.VarChar(20)
  created_at             DateTime                @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  listing_package_orders listing_package_orders? @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model promotions {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String   @db.VarChar(100)
  discount_rate Decimal? @db.Decimal(4, 2)
  start_date    DateTime @db.Date
  end_date      DateTime @db.Date
  code          String?  @unique @db.VarChar(20)
  created_at    DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model properties {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                  String                   @db.VarChar(150)
  price                  Decimal                  @db.Decimal(12, 2)
  type_id                Int?
  location               String
  latitude               Decimal?                 @db.Decimal(10, 8)
  longitude              Decimal?                 @db.Decimal(11, 8)
  description            String?
  bedrooms               Int?                     @default(0)
  bathrooms              Int?                     @default(0)
  area_sqm               Decimal?                 @db.Decimal(8, 2)
  status                 String?                  @default("pending") @db.VarChar(20)
  agent_id               String?                  @db.Uuid
  province_id            Int?
  amphure_id             Int?
  district_id            Int?
  created_at             DateTime                 @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  appointments           appointments[]
  chat_sessions          chat_sessions[]
  listing_package_orders listing_package_orders[]
  users                  users?                   @relation(fields: [agent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  property_types         property_types?          @relation(fields: [type_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  provinces              provinces?               @relation(fields: [province_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  amphures               amphures?                @relation(fields: [amphure_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  districts              districts?               @relation(fields: [district_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  property_amenities     property_amenities[]
  property_documents     property_documents[]
  property_images        property_images[]
  property_nearbies      property_nearbies[]
  reports                reports[]
  sale_transactions      sale_transactions[]
  saved_properties       saved_properties[]

  @@index([agent_id], map: "idx_properties_agent")
  @@index([status], map: "idx_properties_status")
  @@index([province_id], map: "idx_properties_province")
  @@index([amphure_id], map: "idx_properties_amphure")
  @@index([district_id], map: "idx_properties_district")
}

model property_amenities {
  property_id String     @db.Uuid
  amenity_id  Int
  amenities   amenities  @relation(fields: [amenity_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  properties  properties @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([property_id, amenity_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model property_documents {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  property_id String?     @db.Uuid
  doc_url     String      @db.VarChar(255)
  doc_type    String?     @db.VarChar(50)
  status      String?     @default("pending") @db.VarChar(20)
  created_at  DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  properties  properties? @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model property_images {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  property_id String?     @db.Uuid
  image_url   String      @db.VarChar(255)
  order_index Int?        @default(0)
  created_at  DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  properties  properties? @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model property_nearbies {
  property_id     String        @db.Uuid
  nearby_place_id Int
  distance_meters Decimal?      @db.Decimal(6, 1)
  nearby_places   nearby_places @relation(fields: [nearby_place_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  properties      properties    @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([property_id, nearby_place_id])
}

model property_types {
  id         Int          @id @default(autoincrement())
  name       String       @unique @db.VarChar(50)
  created_at DateTime     @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  properties properties[]
}

model quick_reply_templates {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_id   String?  @db.Uuid
  title      String   @db.VarChar(100)
  content    String
  created_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users      users?   @relation(fields: [agent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
