  created_at                             DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users_reports_reported_agent_idTousers users?      @relation("reports_reported_agent_idTousers", fields: [reported_agent_id], references: [id], onUpdate: NoAction)
  properties                             properties? @relation(fields: [reported_property_id], references: [id], onUpdate: NoAction)
  users_reports_reporter_idTousers       users?      @relation("reports_reporter_idTousers", fields: [reporter_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
